WITH TableInfo AS (
    SELECT 
        t.name AS TableName, 
        o.create_date AS CreationDate
    FROM 
        sys.objects o 
    INNER JOIN 
        sys.tables t ON o.object_id = t.object_id
    WHERE 
        o.type_desc = 'USER_TABLE'
),
TableRows AS (
    SELECT 
        t.name AS TableName, 
        SUM(p.rows) AS TotalRows
    FROM 
        sys.tables t
    JOIN 
        sys.partitions p ON t.object_id = p.object_id 
        AND p.index_id IN (0, 1)
    GROUP BY 
        t.name
),
TableSizes AS (
    SELECT
        t.name AS TableName,
       -- SUM(a.total_pages) * 8.0 / 1024 AS TotalSizeMB,
        SUM(a.used_pages) * 8.0 / 1024 AS UsedSizeMB,
		SUM(a.used_pages) * 8.0  AS UsedSizeKB
        --SUM(a.data_pages) * 8.0 / 1024 AS DataSizeMB
    FROM 
        sys.tables t
    JOIN 
        sys.partitions p ON t.object_id = p.object_id
    JOIN 
        sys.allocation_units a ON p.partition_id = a.container_id
    GROUP BY 
        t.name
)
SELECT 
    ti.TableName,
    ti.CreationDate,
    tr.TotalRows
    --ts.UsedSizeKB,
    --ts.UsedSizeMB
    
FROM 
    TableInfo ti
JOIN 
    TableRows tr ON ti.TableName = tr.TableName
JOIN 
    TableSizes ts ON ti.TableName = ts.TableName
ORDER BY 
    tr.TotalRows DESC;
