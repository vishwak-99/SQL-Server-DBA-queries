;WITH backup_cte AS
(
    SELECT
        database_name,
        backup_type =
            CASE type
                WHEN 'D' THEN 'full'
                WHEN 'L' THEN 'log'
                WHEN 'I' THEN 'differential'
                ELSE 'other'
            END,
        backup_start_date,
        backup_finish_date,
        backup_size_tb = FORMAT(backup_size / 1024.0 / 1024 / 1024 / 1024, 'N2'),
        backup_size_GB = CAST(backup_size / 1024.0 / 1024 / 1024 AS INT),
        backup_size_MB = CAST(backup_size / 1024.0 / 1024 AS INT),
        rownum = 
            ROW_NUMBER() OVER
            (
                PARTITION BY database_name, type 
                ORDER BY backup_finish_date DESC
            ),
        [duration DD HH:MM:SS.ms] = 
            FORMAT(
                DATEDIFF(SECOND, backup_start_date, backup_finish_date) / 86400, '00') + ' ' +
            FORMAT(
                DATEADD(SECOND, DATEDIFF(SECOND, backup_start_date, backup_finish_date) % 86400, 0), 'HH:mm:ss') + '.' +
            FORMAT(
                DATEDIFF(MILLISECOND, backup_start_date, backup_finish_date) % 1000, '000')
    FROM msdb.dbo.backupset
)
SELECT
    database_name,
    backup_type,
    backup_start_date,
    backup_finish_date,
    backup_size_MB,
    backup_size_GB,
    backup_size_tb,
    [duration DD HH:MM:SS.ms]
FROM backup_cte
WHERE rownum = 1 
AND backup_type = 'differential'
ORDER BY backup_finish_date DESC;

