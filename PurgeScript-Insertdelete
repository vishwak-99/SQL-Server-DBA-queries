--exec dbo.[userSp_PurgePersonCreditCardbkcp_Safe02]
/*
--CREATE TABLE purgedb.dbo.PurgeAuditLogPersonCreditCardbkcp
--(
--    AuditID          INT IDENTITY(1,1) PRIMARY KEY,  
--    BatchID          UNIQUEIDENTIFIER   NOT NULL,    
--    TableName        NVARCHAR(128)      NOT NULL,    
--    [BatchSize]        INT                NOT NULL,    
--    TotalRowsInRange INT                NOT NULL,    
--    RowsDeleted      INT                NOT NULL,    
--    RowsLeftToDelete INT                NOT NULL,    
--    BatchStartTime   DATETIME           NOT NULL,    
--    BatchEndTime     DATETIME           NOT NULL,    
--    PurgeFromDate    DATETIME           NOT NULL,    
--    PurgeToDate      DATETIME           NOT NULL,    
--    [Status]         NVARCHAR(50)       NOT NULL,    
--    ErrorMessage     NVARCHAR(4000)     NULL         
--);




*/
CREATE OR ALTER PROCEDURE dbo.[userSp_PurgePersonCreditCardbkcp_Safe02]
AS
BEGIN
    SET NOCOUNT ON;
    SET XACT_ABORT ON;

    IF @@TRANCOUNT > 0
    BEGIN
        RAISERROR (
            'Unexpected open transaction detected. Please rollback or commit before running purge.'
            ,16
            ,1
        );
        RETURN;
    END

    DECLARE @BatchID          UNIQUEIDENTIFIER = NEWID();
    DECLARE @BatchNumber      INT = 0;
    DECLARE @RowsDeleted      INT = 0;
    DECLARE @TotalDeleted     INT = 0;
    DECLARE @RowsLeftToDelete INT = 0;
    DECLARE @TotalRowsInRange INT = 0;
    DECLARE @BatchStartTime   DATETIME;
    DECLARE @BatchEndTime     DATETIME;
    DECLARE @ErrorMessage     NVARCHAR(4000);
    DECLARE @ErrorSeverity    INT;
    DECLARE @ErrorState       INT;
    DECLARE @StatusValue      NVARCHAR(50);

    DECLARE @StartDate  DATETIME = '2011-01-01'; /* Change the start date range */
    DECLARE @EndDate    DATETIME = '2013-01-01'; /* Change the end date range */
    DECLARE @ChunkSize  INT      = 1000;         /* Change ChunkSize as per system specs */
    DECLARE @TableName  NVARCHAR(128) = 'Production.WorkOrderRouting'; /* Change table name */

    INSERT INTO purgedb.dbo.[PurgeAuditLogPersonCreditCardbkcp01] (
         BatchID, TableName, [BatchSize], TotalRowsInRange
        ,RowsDeleted, RowsLeftToDelete
        ,BatchStartTime, BatchEndTime
        ,PurgeFromDate, PurgeToDate
        ,[Status], ErrorMessage
    )
    SELECT
         BatchID, TableName, [BatchSize], TotalRowsInRange
        ,0, RowsLeftToDelete
        ,GETDATE(), GETDATE()
        ,PurgeFromDate, PurgeToDate
        ,'KILLED'
        ,'Session was hard-killed (KILL spid) before purge completed.'
         + ' | Rows deleted: ' + CAST(TotalRowsInRange - RowsLeftToDelete AS NVARCHAR(20))
         + ' out of '          + CAST(TotalRowsInRange AS NVARCHAR(20))
         + ' | Remaining: '    + CAST(RowsLeftToDelete AS NVARCHAR(20))
         + ' | Last batch ended: ' + CONVERT(NVARCHAR(30), BatchEndTime, 120)
         + ' | Killed at: '    + CONVERT(NVARCHAR(30), GETDATE(), 120)
    FROM (
        SELECT TOP 1 *
        FROM purgedb.dbo.[PurgeAuditLogPersonCreditCardbkcp01]
        WHERE [Status] = 'RUNNING'
          AND BatchEndTime < DATEADD(MINUTE, -2, GETDATE())
        ORDER BY BatchEndTime DESC
    ) AS orphaned;

    /* 
    -- Get initial count (only rows not already backed up) 
    */
    SELECT
         @RowsLeftToDelete = COUNT(1)
        ,@TotalRowsInRange = COUNT(1)
    FROM [AdventureWorks2022Simulate].[Production].[WorkOrderRouting] s
    WHERE [ModifiedDate] BETWEEN @StartDate AND @EndDate
      AND NOT EXISTS (
          SELECT 1
          FROM purgedb.dbo.[WorkOrderRoutingbackup] b
          WHERE b.[WorkOrderID]       = s.[WorkOrderID]
            AND b.[ProductID]         = s.[ProductID]
            AND b.[OperationSequence] = s.[OperationSequence]
      );

    IF @RowsLeftToDelete = 0
    BEGIN
        PRINT 'No rows found in the given date range OR all rows already backed up. Exiting.';
        RETURN;
    END

    BEGIN TRY
        WHILE 1 = 1
        BEGIN
            SET @BatchStartTime = GETDATE();
            SET @BatchNumber    = @BatchNumber + 1;

            BEGIN TRANSACTION;

                DELETE TOP (@ChunkSize)
                FROM [AdventureWorks2022Simulate].[Production].[WorkOrderRouting]
                OUTPUT
                     DELETED.[WorkOrderID]
                    ,DELETED.[ProductID]
                    ,DELETED.[OperationSequence]
                    ,DELETED.[LocationID]
                    ,DELETED.[ScheduledStartDate]
                    ,DELETED.[ScheduledEndDate]
                    ,DELETED.[ActualStartDate]
                    ,DELETED.[ActualEndDate]
                    ,DELETED.[ActualResourceHrs]
                    ,DELETED.[PlannedCost]
                    ,DELETED.[ActualCost]
                    ,DELETED.[ModifiedDate]
                INTO purgedb.dbo.[WorkOrderRoutingbackup]
                WHERE [ModifiedDate] BETWEEN @StartDate AND @EndDate
                  AND NOT EXISTS (
                      SELECT 1
                      FROM purgedb.dbo.[WorkOrderRoutingbackup] b
                      WHERE b.[WorkOrderID]       = [WorkOrderRouting].[WorkOrderID]
                        AND b.[ProductID]         = [WorkOrderRouting].[ProductID]
                        AND b.[OperationSequence] = [WorkOrderRouting].[OperationSequence]
                  );

            SET @RowsDeleted = @@ROWCOUNT;

            COMMIT TRANSACTION;

            SET @TotalDeleted = @TotalDeleted + @RowsDeleted;
            SET @BatchEndTime = GETDATE();

         /*   -- Recount remaining rows --excluding already backed up-- */
            SELECT @RowsLeftToDelete = COUNT(1)
            FROM [AdventureWorks2022Simulate].[Production].[WorkOrderRouting] s
            WHERE [ModifiedDate] BETWEEN @StartDate AND @EndDate
              AND NOT EXISTS (
                  SELECT 1
                  FROM purgedb.dbo.[WorkOrderRoutingbackup] b
                  WHERE b.[WorkOrderID]       = s.[WorkOrderID]
                    AND b.[ProductID]         = s.[ProductID]
                    AND b.[OperationSequence] = s.[OperationSequence]
              );

            INSERT INTO purgedb.dbo.[PurgeAuditLogPersonCreditCardbkcp01] (
                 BatchID, TableName, [BatchSize], TotalRowsInRange
                ,RowsDeleted, RowsLeftToDelete
                ,BatchStartTime, BatchEndTime
                ,PurgeFromDate, PurgeToDate
                ,[Status], ErrorMessage
            )
            VALUES (
                 @BatchID, @TableName, @ChunkSize, @TotalRowsInRange
                ,@RowsDeleted, @RowsLeftToDelete
                ,@BatchStartTime, @BatchEndTime
                ,@StartDate, @EndDate
                ,CASE WHEN @RowsLeftToDelete = 0 THEN 'SUCCESS' ELSE 'RUNNING' END
                ,NULL
            );

          /*  -- Exit condition — do not modify */
            IF @RowsDeleted = 0 OR @RowsLeftToDelete = 0
            BEGIN
                IF @RowsDeleted = 0
                    PRINT 'Nothing to delete — no eligible rows found. Exiting.';
                IF @RowsLeftToDelete = 0
                    PRINT 'Purge complete. Total rows deleted: ' + CAST(@TotalDeleted AS NVARCHAR(20));
                BREAK;
            END
        END
    END TRY

    BEGIN CATCH
        IF @@TRANCOUNT > 0
            ROLLBACK TRANSACTION;

        SET @ErrorMessage  = ERROR_MESSAGE();
        SET @ErrorSeverity = ERROR_SEVERITY();
        SET @ErrorState    = ERROR_STATE();
        SET @BatchEndTime  = GETDATE();
        SET @StatusValue   = 'FAILED';

        PRINT 'Error caught at batch ' + CAST(@BatchNumber AS NVARCHAR(10))
            + ': ' + ISNULL(@ErrorMessage, 'Unknown');

        INSERT INTO purgedb.dbo.[PurgeAuditLogPersonCreditCardbkcp01] (
             BatchID, TableName, [BatchSize], TotalRowsInRange
            ,RowsDeleted, RowsLeftToDelete
            ,BatchStartTime, BatchEndTime
            ,PurgeFromDate, PurgeToDate
            ,[Status], ErrorMessage
        )
        VALUES (
             @BatchID, @TableName, @ChunkSize, @TotalRowsInRange
            ,0, @RowsLeftToDelete
            ,@BatchStartTime, @BatchEndTime
            ,@StartDate, @EndDate
            ,@StatusValue
            ,@StatusValue + ' at batch ' + CAST(@BatchNumber AS NVARCHAR(10))
             + ' | Reason: '   + ISNULL(@ErrorMessage, 'Unknown')
             + ' | Severity: ' + CAST(ISNULL(@ErrorSeverity, 0) AS NVARCHAR(10))
             + ' | State: '    + CAST(ISNULL(@ErrorState, 0) AS NVARCHAR(10))
        );

        IF @ErrorSeverity > 0
            RAISERROR(@ErrorMessage, @ErrorSeverity, @ErrorState);
    END CATCH
END
GO
