SELECT @@servername,
    concat(',','''',D.name,'''') AS [Database Name],
    c.name AS [Cert Name],
    E.encryptor_type AS [Type],
    CASE
        WHEN E.encryption_state = 3 THEN 'Encrypted'
        WHEN E.encryption_state = 2 THEN 'In Progress'
        ELSE 'Not Encrypted'
    END AS [State],
    E.encryption_state ,
    E.percent_complete
    --E.key_algorithm, 
    --E.key_length, 
    --E.*
FROM 
    sys.dm_database_encryption_keys E
RIGHT JOIN 
    sys.databases D ON D.database_id = E.database_id
LEFT JOIN 
    sys.certificates c ON E.encryptor_thumbprint = c.thumbprint
WHERE 
    D.database_id > 4 
	--and E.encryption_state <>3
	order by D.name

