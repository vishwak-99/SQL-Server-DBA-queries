create or alter procedure dbo.usp_PurgingTest 
(
@TableName nvarchar(400),
@AuditTableName nvarchar(400),
@RefColumn nvarchar(128), 
@WhereClause nvarchar(MAX),
@ChunkSize int = 10000, 
@MaxDOP int = 1, 
@BatchDelay char(8) = '00:00:00'
)
as
begin
	set nocount on;
	set xact_abort on;
	set deadlock_priority LOW;

	declare @CompatLevel int = (
			select compatibility_level
			from sys.databases
			where database_id = DB_ID()
			);

	if @CompatLevel < 100
	begin
		raiserror ('Database compatibility level is %d. Must be 100 or higher.', 16, 1, @CompatLevel);

		return;
	end

	declare @RecoveryModel nvarchar(60) = (
			select recovery_model_desc
			from sys.databases
			where database_id = DB_ID()
			);

	print 'Recovery model: ' + @RecoveryModel + case when @RecoveryModel in (N'SIMPLE', N'BULK_LOGGED') then N' — CHECKPOINT will run every 5000 batches.' else N' — Issue LOG BACKUPs to manage log growth.' end;

	if @TableName is null or @AuditTableName is null or @RefColumn is null or @WhereClause is null
	begin
		raiserror ('@TableName, @AuditTableName, @RefColumn, and @WhereClause cannot be NULL.', 16, 1);

		return;
	end

	if @ChunkSize <= 0 or @ChunkSize > 50000
	begin
		raiserror ('@ChunkSize must be between 1 and 50000.', 16, 1);

		return;
	end

	declare @Safe bit = dbo.fn_Clause(@Clause);

	if @Safe = 0
	begin
		raiserror ('Unsafe WHERE clause detected. Execution aborted.', 16, 1);

		return;
	end

	declare @AuditDBName nvarchar(128) = PARSENAME(@AuditTableName, 3);
	declare @AuditSchemaName nvarchar(128) = ISNULL(PARSENAME(@AuditTableName, 2), N'dbo');
	declare @AuditBaseTable nvarchar(128) = PARSENAME(@AuditTableName, 1);

	if @AuditBaseTable is null
	begin
		set @AuditSchemaName = N'dbo';
		set @AuditBaseTable = @AuditTableName;
	end

	declare @FullAuditName nvarchar(500) = case when @AuditDBName is not null then QUOTENAME(@AuditDBName) + N'.' + QUOTENAME(@AuditSchemaName) + N'.' + QUOTENAME(@AuditBaseTable) else QUOTENAME(@AuditSchemaName) + N'.' + QUOTENAME(@AuditBaseTable) end;

	begin try
		declare @TableExists int;
		declare @CheckSQL nvarchar(MAX) = N'SELECT @exists = CASE WHEN OBJECT_ID(@fullname, ''U'') IS NOT NULL THEN 1 ELSE 0 END';

		exec sp_executesql @CheckSQL, N'@fullname NVARCHAR(500), @exists INT OUTPUT', @fullname = @FullAuditName, @exists = @TableExists output;

		if @TableExists = 0
		begin
			declare @CreateSQL nvarchar(MAX) = N'CREATE TABLE ' + @FullAuditName + 
				N'
                (
                    AuditID           INT IDENTITY(1,1)  NOT NULL,
                    BatchID           UNIQUEIDENTIFIER   NOT NULL,
                    TableName         NVARCHAR(400)      NOT NULL,
                    BatchSize         INT                NOT NULL,
                    TotalRowsInRange  INT                NOT NULL,
                    RowsDeleted       INT                NOT NULL,
                    RowsLeftToDelete  INT                NOT NULL,
                    BatchStartTime    DATETIME2          NOT NULL,
                    BatchEndTime      DATETIME2          NOT NULL,
                    RangeDeletion     NVARCHAR(500)      NOT NULL,
                    [Status]          NVARCHAR(50)       NOT NULL,
                    ErrorMessage      NVARCHAR(4000)     NULL,
                    ChunkRangeDetails NVARCHAR(MAX)      NULL,
                    CONSTRAINT PK_PurgeAuditLog PRIMARY KEY CLUSTERED (AuditID)
                );
                CREATE NONCLUSTERED INDEX IX_PurgeAuditLog_TableName_BatchEndTime
                    ON ' 
				+ @FullAuditName + N' (TableName, BatchEndTime DESC)
                    INCLUDE (Status, RowsLeftToDelete, TotalRowsInRange, BatchID);';

			exec sp_executesql @CreateSQL;

			print 'Audit table created: ' + @FullAuditName;
		end
		else
		begin
			/* Add ChunkRangeDetails column if it was missing from an older version */
			declare @AddColSQL nvarchar(MAX) = N'
                IF NOT EXISTS
                (
                    SELECT 1
                    FROM   ' + case when @AuditDBName is not null then QUOTENAME(@AuditDBName) + N'.sys.columns' else N'sys.columns' end + N'
                    WHERE  object_id = OBJECT_ID(''' + @FullAuditName + N''')
                    AND    name      = ''ChunkRangeDetails''
                )
                ALTER TABLE ' + @FullAuditName + N'
                    ADD ChunkRangeDetails NVARCHAR(MAX) NULL;';

			exec sp_executesql @AddColSQL;
		end
	end try

	begin catch
		declare @AuditErrMsg nvarchar(4000) = ERROR_MESSAGE();

		raiserror ('Failed to ensure audit table exists: %s', 16, 1, @AuditErrMsg);

		return;
	end catch

	declare @SourceDBName nvarchar(128) = PARSENAME(@TableName, 3);
	declare @SchemaName nvarchar(128) = ISNULL(PARSENAME(@TableName, 2), N'dbo');
	declare @BaseTableName nvarchar(128) = PARSENAME(@TableName, 1);

	if @BaseTableName is null
	begin
		set @SchemaName = N'dbo';
		set @BaseTableName = @TableName;
	end

	declare @FullTableName nvarchar(256) = case when @SourceDBName is not null then QUOTENAME(@SourceDBName) + N'.' + QUOTENAME(@SchemaName) + N'.' + QUOTENAME(@BaseTableName) else QUOTENAME(@SchemaName) + N'.' + QUOTENAME(@BaseTableName) end;
	declare @BatchID uniqueidentifier;
	declare @BatchNumber int = 0;
	declare @RowsDeleted int = 0;
	declare @TotalDeleted int = 0;
	declare @RowsLeftToDelete int = 0;
	declare @TotalRowsInRange int = 0;
	declare @BatchStartTime datetime2;
	declare @BatchEndTime datetime2;
	declare @RangeMessage nvarchar(500);
	declare @MinRefValue nvarchar(50);
	declare @MaxRefValue nvarchar(50);
	declare @SQL nvarchar(MAX);
	declare @CurrentRunningAuditID int;
	declare @AuditInsertTemplate nvarchar(MAX) = N'INSERT INTO ' + @FullAuditName + N'
            (BatchID, TableName, BatchSize, TotalRowsInRange, RowsDeleted,
             RowsLeftToDelete, BatchStartTime, BatchEndTime,
             RangeDeletion, [Status], ErrorMessage, ChunkRangeDetails)
          VALUES
            (@BatchIDParam, @TableNameParam, @ChunkSizeParam, @TotalRowsInRangeParam,
             @RowsDeletedParam, @RowsLeftToDeleteParam, @BatchStartTimeParam, @BatchEndTimeParam,
             @RangeMessageParam, @StatusParam, @ErrMsgParam, @ChunkRangeDetailsParam);
          SELECT @NewAuditIDParam = SCOPE_IDENTITY();';
	declare @AuditInsertParamDef nvarchar(MAX) = N'@BatchIDParam           UNIQUEIDENTIFIER,
          @TableNameParam         NVARCHAR(400),
          @ChunkSizeParam         INT,
          @TotalRowsInRangeParam  INT,
          @RowsDeletedParam       INT,
          @RowsLeftToDeleteParam  INT,
          @BatchStartTimeParam    DATETIME2,
          @BatchEndTimeParam      DATETIME2,
          @RangeMessageParam      NVARCHAR(500),
          @StatusParam            NVARCHAR(50),
          @ErrMsgParam            NVARCHAR(4000),
          @ChunkRangeDetailsParam NVARCHAR(MAX),
          @NewAuditIDParam        INT OUTPUT';
	/* -- Reusable UPDATE template: updates a specific AuditID row by PK */
	declare @AuditUpdateTemplate nvarchar(MAX) = N'UPDATE ' + @FullAuditName + N'
          SET    [Status]          = @StatusParam,
                 BatchEndTime      = @BatchEndTimeParam,
                 RowsDeleted       = @RowsDeletedParam,
                 RowsLeftToDelete  = @RowsLeftToDeleteParam,
                 ErrorMessage      = @ErrMsgParam
          WHERE  AuditID           = @AuditIDParam;';
	declare @AuditUpdateParamDef nvarchar(MAX) = N'@AuditIDParam        INT,
          @StatusParam         NVARCHAR(50),
          @BatchEndTimeParam   DATETIME2,
          @RowsDeletedParam    INT,
          @RowsLeftToDeleteParam INT,
          @ErrMsgParam         NVARCHAR(4000)';

	begin try
		declare @OrphanBatchID uniqueidentifier;
		declare @OrphanAuditID int;

		set @SQL = N'SELECT TOP 1
                  @OrphanBatchIDOut = BatchID,
                  @OrphanAuditIDOut = AuditID
              FROM   ' + @FullAuditName + N'
              WHERE  TableName = @TableNameParam
              AND    [Status]  = ''RUNNING''
              ORDER  BY AuditID DESC;';

		exec sp_executesql @SQL, N'@TableNameParam    NVARCHAR(400),
              @OrphanBatchIDOut  UNIQUEIDENTIFIER OUTPUT,
              @OrphanAuditIDOut  INT OUTPUT', @TableNameParam = @TableName, @OrphanBatchIDOut = @OrphanBatchID output, @OrphanAuditIDOut = @OrphanAuditID output;

		if @OrphanAuditID is not null
		begin
			set @BatchEndTime = GETDATE();

			exec sp_executesql @AuditUpdateTemplate, @AuditUpdateParamDef, @AuditIDParam = @OrphanAuditID, @StatusParam = N'KILLED', @BatchEndTimeParam = @BatchEndTime, @RowsDeletedParam = 0, @RowsLeftToDeleteParam = 0, @ErrMsgParam = N'Batch was interrupted by a KILL command, job stop, or server restart.DELETE was rolled back. RowsDeleted = 0 for this batch. Next run resumed under the same BatchID. '

			/*  -- Resume under the same BatchID so the session audit trail is continuous. */
			set @BatchID = @OrphanBatchID;

			print 'Orphaned RUNNING row (AuditID=' + CAST(@OrphanAuditID as nvarchar(20)) + ') marked KILLED. Resuming under BatchID: ' + CAST(@BatchID as nvarchar(50));
		end
		else
		begin
			set @BatchID = NEWID();

			print 'No orphaned session found. Starting fresh. BatchID: ' + CAST(@BatchID as nvarchar(50));
		end
	end try

	begin catch
		declare @OrphanErrMsg nvarchar(4000) = ERROR_MESSAGE();
		declare @OrphanErrSeverity int = ERROR_SEVERITY();
		declare @OrphanErrState int = ERROR_STATE();

		raiserror ('Orphan handler failed: %s', @OrphanErrSeverity, @OrphanErrState, @OrphanErrMsg);

		return;
	end catch

	begin try
		declare @LiveRunning int = 0;

		set @SQL = N'SELECT @LiveRunningOut = COUNT(1)
              FROM   ' + @FullAuditName + N'
              WHERE  TableName = @TableNameParam
              AND    [Status]  = ''RUNNING'';';

		exec sp_executesql @SQL, N'@TableNameParam  NVARCHAR(400),
              @LiveRunningOut  INT OUTPUT', @TableNameParam = @TableName, @LiveRunningOut = @LiveRunning output;

		if @LiveRunning > 0
		begin
			raiserror ('Table ''%s'' is currently being purged by another active session.A RUNNING batch row exists in the audit log. Wait for it to complete or investigate before retrying. ', 16, 1, @TableName);

			return;
		end
	end try

	begin catch
		declare @GuardErrMsg nvarchar(4000) = ERROR_MESSAGE();
		declare @GuardErrSeverity int = ERROR_SEVERITY();
		declare @GuardErrState int = ERROR_STATE();

		raiserror ('Concurrent run guard failed: %s', @GuardErrSeverity, @GuardErrState, @GuardErrMsg);

		return;
	end catch

	declare @DeleteTemplate nvarchar(MAX) = N'DELETE TOP (@ChunkSizeParam)
          FROM  ' + @FullTableName + N'
          WHERE ' + @WhereClause + N'
          OPTION (MAXDOP ' + CAST(@MaxDOP as nvarchar(2)) + N');';

	set @SQL = N'SELECT
              @MinRef = COALESCE(CAST(MIN(' + QUOTENAME(@RefColumn) + N') AS VARCHAR(50)), ''NoRecordsFoundForThisRange''),
              @MaxRef = COALESCE(CAST(MAX(' + QUOTENAME(@RefColumn) + N') AS VARCHAR(50)), ''NoRecordsFoundForThisRange'')
          FROM ' + @FullTableName + N'
          WHERE ' + @WhereClause;

	exec sp_executesql @SQL, N'@MinRef NVARCHAR(50) OUTPUT, @MaxRef NVARCHAR(50) OUTPUT', @MinRef = @MinRefValue output, @MaxRef = @MaxRefValue output;

	set @RangeMessage = N'Date range for deletion: ' + @MinRefValue + N' to ' + @MaxRefValue;

	begin try
		set @SQL = N'SELECT @RowsLeftToDelete = COUNT(1),
                     @TotalRowsInRange = COUNT(1)
              FROM   ' + @FullTableName + N'
              WHERE  ' + @WhereClause;

		exec sp_executesql @SQL, N'@RowsLeftToDelete INT OUTPUT, @TotalRowsInRange INT OUTPUT', @RowsLeftToDelete = @RowsLeftToDelete output, @TotalRowsInRange = @TotalRowsInRange output;

		set @BatchStartTime = GETDATE();
		set @BatchEndTime = GETDATE();

		if @RowsLeftToDelete = 0
		begin
			print 'No rows match the WHERE clause. Exiting.';

			declare @NoRowsMsg nvarchar(4000) = N'No records found for deletion. Table: ' + @TableName + N' | Range: ' + @RangeMessage;
			declare @DummyAuditID int;

			exec sp_executesql @AuditInsertTemplate, @AuditInsertParamDef, @BatchIDParam = @BatchID, @TableNameParam = @TableName, @ChunkSizeParam = @ChunkSize, @TotalRowsInRangeParam = 0, @RowsDeletedParam = 0, @RowsLeftToDeleteParam = 0, @BatchStartTimeParam = @BatchStartTime, @BatchEndTimeParam = @BatchEndTime, @RangeMessageParam = @RangeMessage, @StatusParam = N'NO_RECORDS_FOUND', @ErrMsgParam = @NoRowsMsg, @ChunkRangeDetailsParam = null, @NewAuditIDParam = @DummyAuditID output;

			return;
		end
	end try

	begin catch
		declare @InitErrMsg nvarchar(4000) = ERROR_MESSAGE();
		declare @InitErrSeverity int = ERROR_SEVERITY();
		declare @InitErrState int = ERROR_STATE();
		declare @InitDummyID int;

		exec sp_executesql @AuditInsertTemplate, @AuditInsertParamDef, @BatchIDParam = @BatchID, @TableNameParam = @TableName, @ChunkSizeParam = @ChunkSize, @TotalRowsInRangeParam = @TotalRowsInRange, @RowsDeletedParam = 0, @RowsLeftToDeleteParam = @RowsLeftToDelete, @BatchStartTimeParam = @BatchStartTime, @BatchEndTimeParam = @BatchEndTime, @RangeMessageParam = @RangeMessage, @StatusParam = N'FAILED', @ErrMsgParam = @InitErrMsg, @ChunkRangeDetailsParam = null, @NewAuditIDParam = @InitDummyID output;

		raiserror (@InitErrMsg, @InitErrSeverity, @InitErrState);
	end catch

	begin try
		declare @ExistingStarted int = 0;
		declare @SentinelDummyID int;

		set @SQL = N'SELECT @ExistingStartedOut = COUNT(1)
              FROM   ' + @FullAuditName + N'
              WHERE  BatchID  = @BatchIDParam
              AND    [Status] = ''STARTED'';';

		exec sp_executesql @SQL, N'@BatchIDParam         UNIQUEIDENTIFIER,
              @ExistingStartedOut   INT OUTPUT', @BatchIDParam = @BatchID, @ExistingStartedOut = @ExistingStarted output;

		if @ExistingStarted = 0
		begin
			exec sp_executesql @AuditInsertTemplate, @AuditInsertParamDef, @BatchIDParam = @BatchID, @TableNameParam = @TableName, @ChunkSizeParam = @ChunkSize, @TotalRowsInRangeParam = @TotalRowsInRange, @RowsDeletedParam = 0, @RowsLeftToDeleteParam = @RowsLeftToDelete, @BatchStartTimeParam = @BatchStartTime, @BatchEndTimeParam = @BatchEndTime, @RangeMessageParam = @RangeMessage, @StatusParam = N'STARTED', @ErrMsgParam = null, @ChunkRangeDetailsParam = null, @NewAuditIDParam = @SentinelDummyID output;

			print 'STARTED sentinel written. BatchID: ' + CAST(@BatchID as nvarchar(50));
		end
		else
		begin
			print 'Resuming killed session. Existing STARTED sentinel retained. BatchID: ' + CAST(@BatchID as nvarchar(50));
		end
	end try

	begin catch
		declare @SentinelErrMsg nvarchar(4000) = ERROR_MESSAGE();
		declare @SentinelErrSeverity int = ERROR_SEVERITY();
		declare @SentinelErrState int = ERROR_STATE();

		raiserror ('Failed to write STARTED sentinel: %s', @SentinelErrSeverity, @SentinelErrState, @SentinelErrMsg);

		return;
	end catch

	begin try
		while 1 = 1
		begin
			set @BatchNumber = @BatchNumber + 1;
			set @BatchStartTime = GETDATE();
			set @CurrentRunningAuditID = null;

			exec sp_executesql @AuditInsertTemplate, @AuditInsertParamDef, @BatchIDParam = @BatchID, @TableNameParam = @TableName, @ChunkSizeParam = @ChunkSize, @TotalRowsInRangeParam = @TotalRowsInRange, @RowsDeletedParam = 0, @RowsLeftToDeleteParam = @RowsLeftToDelete, @BatchStartTimeParam = @BatchStartTime, @BatchEndTimeParam = @BatchStartTime, -- no end time yet
				@RangeMessageParam = @RangeMessage, @StatusParam = N'RUNNING', @ErrMsgParam = null, @ChunkRangeDetailsParam = null, @NewAuditIDParam = @CurrentRunningAuditID output;

			begin transaction;

			exec sp_executesql @DeleteTemplate, N'@ChunkSizeParam INT, @MaxDOPParam INT', @ChunkSizeParam = @ChunkSize, @MaxDOPParam = @MaxDOP;

			set @RowsDeleted = @@ROWCOUNT;

			commit transaction;

			set @TotalDeleted = @TotalDeleted + @RowsDeleted;
			set @BatchEndTime = GETDATE();

			waitfor delay @BatchDelay;

			set @SQL = N'SELECT @RowsLeftToDelete = COUNT(1)
                  FROM   ' + @FullTableName + N'
                  WHERE  ' + @WhereClause;

			exec sp_executesql @SQL, N'@RowsLeftToDelete INT OUTPUT', @RowsLeftToDelete = @RowsLeftToDelete output;

			declare @ChunkRangeDetailsJSON nvarchar(MAX);

			if @CompatLevel >= 130
			begin
				/* SQL Server 2016+*/
				set @SQL = N'SELECT @Json = (
                        SELECT
                            @TableNameParam   AS TableName,
                            @MinRefParam      AS MinRefValue,
                            @MaxRefParam      AS MaxRefValue,
                            @WhereClauseParam AS Predicate,
                            @BatchNumberParam AS BatchNumber,
                            @ChunkSizeParam   AS ChunkSize,
                            @MaxDOPParam      AS MaxDOP,
                            @BatchDelayParam  AS BatchDelay
                        FOR JSON PATH, WITHOUT_ARRAY_WRAPPER
                    );';

				exec sp_executesql @SQL, N'@TableNameParam   NVARCHAR(128),
                      @MinRefParam      NVARCHAR(50),
                      @MaxRefParam      NVARCHAR(50),
                      @WhereClauseParam NVARCHAR(MAX),
                      @BatchNumberParam INT,
                      @ChunkSizeParam   INT,
                      @MaxDOPParam      INT,
                      @BatchDelayParam  CHAR(8),
                      @Json             NVARCHAR(MAX) OUTPUT', @TableNameParam = @TableName, @MinRefParam = @MinRefValue, @MaxRefParam = @MaxRefValue, @WhereClauseParam = @WhereClause, @BatchNumberParam = @BatchNumber, @ChunkSizeParam = @ChunkSize, @MaxDOPParam = @MaxDOP, @BatchDelayParam = @BatchDelay, @Json = @ChunkRangeDetailsJSON output;
			end
			else
			begin
				/* SQL Server 2014 — manual JSON build */
				set @ChunkRangeDetailsJSON = N'{"TableName":"' + REPLACE(@TableName, '"', '\"') + N'",' + N'"MinRefValue":"' + REPLACE(@MinRefValue, '"', '\"') + N'",' + N'"MaxRefValue":"' + REPLACE(@MaxRefValue, '"', '\"') + N'",' + N'"Predicate":"' + REPLACE(@WhereClause, '"', '\"') + N'",' + N'"BatchNumber":' + CAST(@BatchNumber as nvarchar(20)) + N',' + N'"ChunkSize":' + CAST(@ChunkSize as nvarchar(20)) + N',' + N'"MaxDOP":' + CAST(@MaxDOP as nvarchar(10)) + N',' + N'"BatchDelay":"' + @BatchDelay + N'"}';
			end

			if @RowsLeftToDelete = 0
			begin
				/*   -- Last batch — update RUNNING → SUCCESS */
				exec sp_executesql @AuditUpdateTemplate, @AuditUpdateParamDef, @AuditIDParam = @CurrentRunningAuditID, @StatusParam = N'SUCCESS', @BatchEndTimeParam = @BatchEndTime, @RowsDeletedParam = @RowsDeleted, @RowsLeftToDeleteParam = 0, @ErrMsgParam = null;

				print 'Purge complete. Total deleted: ' + CAST(@TotalDeleted as nvarchar(20)) + ' in ' + CAST(@BatchNumber as nvarchar(20)) + ' batches.';

				break;
			end
			else
			begin
				/*     -- Normal batch — update RUNNING → COMPLETED */
				exec sp_executesql @AuditUpdateTemplate, @AuditUpdateParamDef, @AuditIDParam = @CurrentRunningAuditID, @StatusParam = N'COMPLETED', @BatchEndTimeParam = @BatchEndTime, @RowsDeletedParam = @RowsDeleted, @RowsLeftToDeleteParam = @RowsLeftToDelete, @ErrMsgParam = null;
			end

			if @BatchNumber % 5000 = 0 and @RecoveryModel in (N'SIMPLE', N'BULK_LOGGED')
			begin
				checkpoint;

				print 'Checkpoint at batch ' + CAST(@BatchNumber as nvarchar(20)) + '. Total deleted: ' + CAST(@TotalDeleted as nvarchar(20));

				waitfor delay '00:00:01';
			end

			if @BatchNumber % 100 = 0
				print 'Batch ' + CAST(@BatchNumber as nvarchar(20)) + ' | Deleted: ' + CAST(@TotalDeleted as nvarchar(20)) + ' | Remaining: ' + CAST(@RowsLeftToDelete as nvarchar(20));
		end
	end try

	begin catch
		if @@TRANCOUNT > 0
			rollback;

		declare @PurgeErrMsg nvarchar(4000) = ERROR_MESSAGE();
		declare @PurgeErrSeverity int = ERROR_SEVERITY();
		declare @PurgeErrState int = ERROR_STATE();

		set @BatchEndTime = GETDATE();

		if @CurrentRunningAuditID is not null
		begin
			exec sp_executesql @AuditUpdateTemplate, @AuditUpdateParamDef, @AuditIDParam = @CurrentRunningAuditID, @StatusParam = N'FAILED', @BatchEndTimeParam = @BatchEndTime, @RowsDeletedParam = 0, @RowsLeftToDeleteParam = @RowsLeftToDelete, @ErrMsgParam = @PurgeErrMsg;
		end

		raiserror (@PurgeErrMsg, @PurgeErrSeverity, @PurgeErrState);
	end catch
end
go

