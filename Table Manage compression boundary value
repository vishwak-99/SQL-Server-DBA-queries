USE DBName
Go
WITH RankedRecords AS (
    SELECT 
        t.name AS TableName, 
        p.partition_number, 
        r.boundary_id, 
        r.value AS BoundaryValue, 
        p.rows,
        ROW_NUMBER() OVER (ORDER BY r.value ASC) AS RowAsc,
        ROW_NUMBER() OVER (ORDER BY r.value DESC) AS RowDesc
    FROM
        sys.tables AS t
    INNER JOIN
        sys.indexes AS i ON t.object_id = i.object_id
    INNER JOIN
        sys.partitions AS p ON i.object_id = p.object_id AND i.index_id = p.index_id
    INNER JOIN
        sys.allocation_units a ON a.container_id = p.hobt_id
    INNER JOIN
        sys.filegroups fg ON fg.data_space_id = a.data_space_id
    INNER JOIN
        sys.partition_schemes AS s ON i.data_space_id = s.data_space_id
    INNER JOIN
        sys.partition_functions AS f ON s.function_id = f.function_id
    LEFT OUTER JOIN
        sys.partition_range_values AS r ON f.function_id = r.function_id AND r.boundary_id = p.partition_number
    WHERE
        t.name = 'TableName'  -- change the table name
        AND i.type <= 1
        AND a.type = 1 -- in row data only
)

SELECT 
    TableName, 
    partition_number, 
    boundary_id, 
    BoundaryValue, 
    rows
FROM RankedRecords
WHERE RowAsc <= 5 OR RowDesc <= 25
ORDER BY 
    CASE 
        WHEN RowAsc <= 10 THEN 1 
        ELSE 2 
    END, 
    BoundaryValue ASC;

